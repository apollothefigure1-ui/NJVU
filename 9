        function CheckPendingRoyaltyInvoices() {
            $.ajax({
                type: "GET",
                contentType: "application/json;charset=utf-8",
                url: 'WebServices.asmx/GetPendingRoyaltyInvoices',
                async: false,
                dataType: "JSON",
                success: function (response) {
                    var Result = JSON.parse(response.d);
                    if (Result && Result.length > 0) {
                        // Only proceed if IsRoyaltyEnable is "True"
                        var isRoyaltyEnabled = false;
                        var DueDate = '';
                        var royaltyAmount = 0;

                        // Check if IsRoyaltyEnable is "True" in at least one invoice
                        for (var i = 0; i < Result.length; i++) {
                            if (Result[i].IsRoyaltyEnable && Result[i].IsRoyaltyEnable.toString().toLowerCase() === "true") {
                                isRoyaltyEnabled = true;
                                DueDate = Result[i].dueDate;

                                // Add royalty amount if available
                                if (Result[i].royalty_amount) {
                                    royaltyAmount += parseFloat(Result[i].royalty_amount || 0);
                                }

                                $('#hdnIsRoyaltyDue').val('True');
                            }
                        }

                        // Only show popup if royalty is enabled
                        if (isRoyaltyEnabled) {
                            var totalPending = Result.length;
                            var totalAmount = 0;

                            // Extract and format the earliest due date from invoices
                            var earliestDueDate = null;
                            var isDatePassed = false;
                            var today = new Date();
                            today.setHours(0, 0, 0, 0); // Set to beginning of the day for comparison

                            // Loop through all invoices to find the earliest due date from dueDate column
                            for (var i = 0; i < Result.length; i++) {
                                // Calculate total amount if available
                                if (Result[i].Net_amount) {
                                    totalAmount += parseFloat(Result[i].Net_amount || 0);
                                }

                                // Extract royalty amount if available
                                if (Result[i].royalty_amount) {
                                    royaltyAmount += parseFloat(Result[i].royalty_amount || 0);
                                }

                                // Extract due date from dueDate column
                                if (Result[i].dueDate) {
                                    var dueDate = new Date(Result[i].dueDate);
                                    // Check if the date is valid
                                    if (!isNaN(dueDate.getTime())) {
                                        // If there's no earliest date yet or this one is earlier, update it
                                        if (!earliestDueDate || dueDate < earliestDueDate) {
                                            earliestDueDate = dueDate;
                                        }
                                    }
                                }
                            }

                            // Format due date as DD-MM-YYYY
                            var formattedDueDate = 'ASAP';
                            if (earliestDueDate) {
                                isDatePassed = earliestDueDate < today;
                                var day = earliestDueDate.getDate();
                                var month = earliestDueDate.getMonth() + 1;
                                var year = earliestDueDate.getFullYear();
                                formattedDueDate = (day < 10 ? '0' + day : day) + '-' +
                                                  (month < 10 ? '0' + month : month) + '-' +
                                                  year;
                            }

                            // Format royalty amount
                            var formattedRoyaltyAmount = '₹' + royaltyAmount.toFixed(2);

                            var Content = 'A royalty payment is pending. We kindly request that you complete your payment by <strong>' + DueDate + '</strong>.<br>Please contact your administrator if you have any questions.</b>';
                            if (isDatePassed == true) {
                                Content = 'Friendly reminder: your royalty payment is overdue. Please contact your administrator if you need assistance.';
                            }

                            // Create and show modal
                            var modalHtml = '<div class="modal" id="royaltyModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">' +
                                '<div class="modal-dialog modal-dialog-center">' +
                                    '<div class="modal-content">' +
                                        '<div class="" style="margin: 5px; font-size: 17px;">' +
                                            '<div class="panel panel-default" style="border: 1px solid #ddd; border-radius: 4px; margin-bottom: 0;">' +
                                                '<div class="panel-body well-sm-tiny" style="padding: 0px;">' +
                                                    '<div class="row-fluid div-margin">' +
                                                        '<div class="col-sm-12">' +
                                                            '<div class="div-margin textCenter" style="padding: 30px;">' +
                                                                '<div class="div-margin" style="color: Red;">' +
                                                                    'Attention Required' +
                                                                '</div>' +
                                                              Content +

                                                            '</div>' +
                                                        '</div>' +
                                                    '</div>' +
                                                '</div>' +
                                                '<div class="panel-footer" style="background-color: #f5f5f5; border-top: 1px solid #ddd; padding: 15px 0; margin-top: 10px;">' +
                                                    '<div class="row-fluid text-center">' +
                                                        (isDatePassed ?
                            // If due date has passed, only show Pay Now button
                                                        '<div class="col-sm-4"></div>' +
                                                        '<div class="col-sm-4">' +
                                                        '<a class="btn btn-primary btn-block btn-lg active btn-style-3" href="Reports/RoyaltyProformaInvoices.aspx">Check Estimate</a>' +
                                                        '</div>' +
                                                        '<div class="col-sm-4"></div>' :
                            // Otherwise show both Pay Now and Skip buttons
                                                        '<div class="col-sm-4 text-right" style="padding-top: 9px;">' +
                                                        '<a href="javascript:void(0);" onclick="$(\'#royaltyModal\').modal(\'hide\');" style="padding-top: 10px; padding-left: 20px;">Skip</a>' +
                                                        '</div>' +
                                                        '<div class="col-sm-4">' +
                                                        '<a class="btn btn-primary btn-block btn-lg active btn-style-3" href="Reports/RoyaltyProformaInvoices.aspx">Check Estimate</a>' +
                                                        '</div>' +
                                                        '<div class="col-sm-4"></div>') +
                                                    '</div>' +
                                                '</div>' +
                                            '</div>' +
                                        '</div>' +
                                    '</div>' +
                                '</div>' +
                            '</div>';

                            // Add modal to body if not exists
                            if (!$('#royaltyModal').length) {
                                $('body').append(modalHtml);
                            }

                            // Show modal with same configuration as order overdue popup
                            $('#royaltyModal').modal({
                                backdrop: 'static',
                                keyboard: false
                            });
                        }
                    }
                },
                error: function (result) {
                    console.error("Error checking royalty invoices:", result);
                }
            });
        }
