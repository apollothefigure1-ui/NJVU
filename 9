        function OnError(xhr, errorType, exception) {
            var responseText;
            try {
                responseText = jQuery.parseJSON(xhr.responseText);
                var ErrorMsg = errorType + "  :  " + exception + " : " + responseText.ExceptionType + " : " + responseText.StackTrace + " : " + responseText.StackTrace + " : " + responseText.Message
                alert(ErrorMsg);
            } catch (e) {
                responseText = xhr.responseText;
                alert(responseText);
            }

        }

        function getParameterByName(name) {
            var ResultData = '';
            var match = RegExp('[?&]' + name + '=([^&]*)').exec(window.location.search);
            if (match && decodeURIComponent(match[1].replace(/\+/g, ' '))) {
                ResultData = match && decodeURIComponent(match[1].replace(/\+/g, ' '));
            }
            else {
                ResultData = '';
            }
            return ResultData;
        }
